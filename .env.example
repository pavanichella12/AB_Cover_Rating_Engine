# LLM provider: google | openai | anthropic | bedrock
# LLM_PROVIDER=google
# LLM_MODEL=

# API key for your chosen provider (uncomment the one you use)
# GOOGLE_API_KEY=your_google_api_key
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key
# For Bedrock: set AWS credentials (e.g. AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY) or use IAM role

# -------- LangSmith (optional: see full prompts & responses at smith.langchain.com) --------
# Get your API key from https://smith.langchain.com → Settings → API Keys
# Add these lines to your .env (copy to .env and fill in the key):
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=abcover
